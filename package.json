{
  "name": "apex-team",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --sequence.shuffle --passWithNoTests",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "devsecops:bootstrap-workspace": "node scripts/devsecops/bootstrap-workspace.mjs",
    "ops:run": "node scripts/ops-run.mjs",
    "qa:feat": "node scripts/qa-feat.mjs",
    "feat:backfill": "node scripts/feat-backfill.mjs",
    "status:reconcile": "node scripts/status-reconcile.mjs",
    "postinstall": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.2.2"
}
