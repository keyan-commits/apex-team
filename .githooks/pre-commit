#!/bin/sh
set -e

# Per-repo opt-out: git config handoff.requireOnCommit false
if [ "$(git config --bool handoff.requireOnCommit 2>/dev/null)" = "false" ]; then
  exit 0
fi

staged=$(git diff --cached --name-only)

# Skip if no runtime code is staged (doc-only commits don't need HANDOFF.md refresh)
if ! echo "$staged" | grep -qE '^(src/|scripts/|tests/|\.github/|package\.json$|server\.ts$|tsconfig\.json$)'; then
  exit 0
fi

# Wave 108 — lint + type-check gates (Piece 1 of #303 regression-gate bundle)
# Only run if pnpm is available and we're in a proper workspace (not a minimal test env)
if command -v pnpm >/dev/null 2>&1 && [ -f "pnpm-lock.yaml" ]; then
  echo "→ Running pre-commit gates (lint + type-check)..."
  pnpm lint --max-warnings 0 --quiet
  pnpm type-check
fi

# Code is staged — require either a HANDOFF.md edit OR a _handoff-pending/*.md fragment.
# (Wave 93+: roles write per-wave fragments instead of editing HANDOFF.md directly.)
has_handoff=$(echo "$staged" | grep -qx 'HANDOFF.md' && echo 1 || echo 0)
has_fragment=$(echo "$staged" | grep -qE '^_handoff-pending/.+\.md$' && echo 1 || echo 0)
if [ "$has_handoff" = "0" ] && [ "$has_fragment" = "0" ]; then
  echo "✗ pre-commit: code is staged but neither HANDOFF.md nor a _handoff-pending/*.md fragment is." >&2
  echo "" >&2
  echo "  Option A (Wave 93+): add _handoff-pending/<wave>-<role>.md with Done/In-flight/Next/Notes." >&2
  echo "  Option B (legacy):   update the HANDOFF.md NOW block and re-stage it." >&2
  echo "  Bypass once:         git commit --no-verify" >&2
  echo "  Disable always:      git config handoff.requireOnCommit false" >&2
  exit 1
fi
