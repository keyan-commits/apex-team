# apex-engine MCP server (default URL — start with `pnpm setup` in ../apex-engine)
APEX_MCP_URL=http://127.0.0.1:31001/mcp

# Optional — only needed if you switch an agent to Gemini or Groq.
# Claude agents reuse local Claude Code OAuth — no API key required.
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# Optional — absolute path to the `claude` CLI binary used by the top
# Terminal pane. Auto-detected on startup (server.ts checks $CLAUDE_BIN,
# `command -v claude`, /opt/homebrew/bin, /usr/local/bin, ~/.local/bin).
# Set this if you want to force a specific install.
# CLAUDE_BIN=/opt/homebrew/bin/claude
