# apex-engine MCP server (default URL — start with `pnpm setup` in ../apex-engine)
APEX_MCP_URL=http://127.0.0.1:31001/mcp

# Server port (default: 3000)
# PORT=3000

# SQLite database path (default: data/apex-team.db)
# APEX_TEAM_DB_PATH=data/apex-team.db

# Optional — only needed if you switch an agent to Gemini or Groq.
# Claude agents reuse local Claude Code OAuth — no API key required.
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=

# Optional — absolute path to the `claude` CLI binary.
# Auto-detected on startup; only set this to force a specific install.
# CLAUDE_BIN=/opt/homebrew/bin/claude
